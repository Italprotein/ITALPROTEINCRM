# Copy to .env.production on the VPS and fill in. NEVER commit the real file.
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# ── The domain Caddy serves + the app's own origin ──────────────────────────
APP_DOMAIN=crm.italprotein.com
APP_URL=https://crm.italprotein.com

# ── Database (used by both the Postgres container and the app) ───────────────
# Strong, random. The app's DATABASE_URL is assembled from this in compose.
POSTGRES_PASSWORD=REPLACE_with_a_long_random_password

# ── Auth / crypto secrets (generate fresh; never reuse the examples) ─────────
# npx auth secret          → AUTH_SECRET
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"  → the keys below
AUTH_SECRET=REPLACE_with_a_long_random_secret
AUTH_COOKIE_DOMAIN=crm.italprotein.com
GOOGLE_TOKEN_ENC_KEY=REPLACE_with_a_long_random_secret
CRON_SECRET=REPLACE_with_a_long_random_secret

# ── Public site/contact values (baked into the client bundle at build) ───────
NEXT_PUBLIC_SITE_URL=https://www.italprotein.com
NEXT_PUBLIC_CONTACT_EMAIL=ad@italprotein.com
NEXT_PUBLIC_CONTACT_PHONE_PRIMARY=+39 351 910 3211
NEXT_PUBLIC_CONTACT_ADDRESS=Galleria Cavour 7, Bologna, Italy

# ── Google Workspace OAuth (Gmail send/sync). Leave blank until configured ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.italprotein.com/api/auth/google/callback
GMAIL_SENDER_EMAIL=ad@italprotein.com
GMAIL_REPLY_TO=ad@italprotein.com

# ── AI assistant (Amina). Optional — the runtime is still stubbed ────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
