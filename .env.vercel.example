# Vercel environment variables — set these in Project Settings → Environment Variables.
# DATABASE_URL must be present at BUILD time too (prisma generate reads it via
# prisma.config.ts), so add every variable to Production AND Preview environments.

NEXT_PUBLIC_SITE_URL=https://www.italprotein.com
NEXT_PUBLIC_CONTACT_EMAIL=ad@italprotein.com
NEXT_PUBLIC_CONTACT_PHONE_PRIMARY=+39 351 910 3211
NEXT_PUBLIC_CONTACT_ADDRESS=Galleria Cavour 7, Bologna, Italy

# Backend-enabled deploy mode. Switch to mock only for a frontend-only preview
# (mock mode still needs a placeholder DATABASE_URL so the build can run).
NEXT_PUBLIC_DATA_MODE=api

# Set to the assigned Vercel domain after the first deploy.
APP_URL=https://YOUR-PROJECT.vercel.app
APP_ENV=production

# Hosted Postgres (Vercel Postgres / Neon / Supabase). Use the POOLED connection
# string — serverless functions open many short-lived connections.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/italprotein_crm

# Required secret for Auth.js session signing. Generate with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-secret

# Leave these blank until the production Google Cloud project is created.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-PROJECT.vercel.app/api/auth/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SHARED_DRIVE_ID=
GOOGLE_WORKSPACE_ADMIN_EMAIL=ad@italprotein.com

GMAIL_SENDER_EMAIL=ad@italprotein.com
GMAIL_REPLY_TO=ad@italprotein.com

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_ASSISTANT_NAME=Amina
# Leave blank until the AI vector store is provisioned.
AI_VECTOR_STORE_URL=

# Optional production integrations. Leave blank until the vendor is chosen.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
ESIGN_PROVIDER=
ESIGN_API_KEY=
CARRIER_TRACKING_PROVIDER=
CARRIER_TRACKING_API_KEY=
PAYMENTS_PROVIDER=
PAYMENTS_API_KEY=
