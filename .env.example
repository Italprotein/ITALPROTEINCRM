# Public site values. These are bundled into the browser at build time.
NEXT_PUBLIC_SITE_URL=https://www.italprotein.com
NEXT_PUBLIC_CONTACT_EMAIL=ad@italprotein.com
NEXT_PUBLIC_CONTACT_PHONE_PRIMARY=+39 351 910 3211
NEXT_PUBLIC_CONTACT_ADDRESS=Galleria Cavour 7, Bologna, Italy

# Runtime mode for the future backend cutover.
# mock = current fixture/localStorage demo, api = production API/server actions.
NEXT_PUBLIC_DATA_MODE=mock
APP_URL=http://localhost:3000
APP_ENV=development

# Production database and auth. Keep real values only in .env.local or hosting secrets.
DATABASE_URL=postgresql://user:password@localhost:5432/italprotein_crm
# Password for the local Docker Postgres (read by docker-compose.yml). Match the password in DATABASE_URL.
POSTGRES_PASSWORD=changeme
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_DOMAIN=localhost

# Google Workspace OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SHARED_DRIVE_ID=
GOOGLE_WORKSPACE_ADMIN_EMAIL=

# Gmail sending identity.
GMAIL_SENDER_EMAIL=ad@italprotein.com
GMAIL_REPLY_TO=ad@italprotein.com

# AI assistant provider (Amina) — Anthropic / Claude.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_ASSISTANT_NAME=Amina
AI_VECTOR_STORE_URL=

# Optional production integrations.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
ESIGN_PROVIDER=
ESIGN_API_KEY=
CARRIER_TRACKING_PROVIDER=
CARRIER_TRACKING_API_KEY=
PAYMENTS_PROVIDER=
PAYMENTS_API_KEY=
