{
  "name": "italprotein-crm",
  "version": "0.1.0",
  "private": true,
  "description": "ITALPROTEIN CRM — bilingual B2B CRM for Italprotein Srl & Proamina®. Next.js + Prisma/Postgres + Auth.js + Gmail; switchable mock/api data mode via NEXT_PUBLIC_DATA_MODE.",
