  vatTotal          Int?
  shippingCost      Int?
  total             Int           @default(0)
  paidAmount        Int           @default(0)
  outstandingAmount Int?
  overdueAmount     Int?
  paymentTerms      String?
  notes             String?
  issuedByUserId    String?
  createdById       String?
  updatedById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  company      Company @relation("CompanyInvoices", fields: [companyId], references: [id])
  order        Order?  @relation("OrderInvoices", fields: [orderId], references: [id])
  issuedByUser User?   @relation("InvoiceIssuedBy", fields: [issuedByUserId], references: [id])

  lineItems   InvoiceLineItem[] @relation("InvoiceLineItems")
  payments    Payment[]         @relation("InvoicePayments")
  creditNotes CreditNote[]      @relation("InvoiceCreditNotes")

  @@index([companyId])
  @@index([orderId])
  @@index([status])
  @@index([paymentStatus])
  @@index([dueDate])
  @@index([issuedByUserId])
  @@map("invoices")
}

model InvoiceLineItem {
  id           String       @id @default(cuid())
  invoiceId    String
  productId    String?
  productName  String
  quantity     Decimal
  unit         QuantityUnit
  pricePerUnit Int
  pricePerKg   Int?
  discountPct  Decimal?
  vatPct       Decimal?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  invoice Invoice  @relation("InvoiceLineItems", fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation("ProductInvoiceLineItems", fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_line_items")
}

model Payment {
  id               String        @id @default(cuid())
  reference        String?
  invoiceId        String
  amount           Int
  currency         Currency      @default(EUR)
  method           PaymentMethod @default(bank_transfer)
  receivedAt       DateTime?
  notes            String?
  recordedByUserId String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  invoice        Invoice @relation("InvoicePayments", fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedByUser User?   @relation("PaymentRecordedBy", fields: [recordedByUserId], references: [id])

  @@index([invoiceId])
  @@index([recordedByUserId])
  @@index([receivedAt])
  @@map("payments")
}

model CreditNote {
  id             String    @id @default(cuid())
  reference      String    @unique
  number         String?
  invoiceId      String
  companyId      String?
  amount         Int
  currency       Currency  @default(EUR)
  reason         String?
  issuedAt       DateTime?
  notes          String?
  issuedByUserId String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoice      Invoice  @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id], onDelete: Cascade)
  company      Company? @relation("CompanyCreditNotes", fields: [companyId], references: [id])
  issuedByUser User?    @relation("CreditNoteIssuedBy", fields: [issuedByUserId], references: [id])

  @@index([invoiceId])
  @@index([companyId])
  @@index([issuedByUserId])
  @@map("credit_notes")
}

/**
 * ══════════════════════════════ Engagement / scheduling / AI models ══════════════════════════════
 */

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  type         TaskType   @default(other)
  status       TaskStatus @default(open)
  priority     Priority   @default(medium)
  source       TaskSource @default(manual)
  companyId    String?
  contactId    String?
  relatedType  String?
  relatedId    String?
  ownerUserId  String
  dueDate      DateTime?
  reminderDate DateTime?
  completedAt  DateTime?
  createdById  String?
  updatedById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company Company? @relation("CompanyTasks", fields: [companyId], references: [id])
  contact Contact? @relation("ContactTasks", fields: [contactId], references: [id])
  owner   User     @relation("TaskOwner", fields: [ownerUserId], references: [id])

  collaborators TaskCollaborator[] @relation("TaskCollaborators")
  comments      TaskComment[]      @relation("TaskComments")

  @@index([companyId])
  @@index([contactId])
  @@index([ownerUserId])
  @@index([status])
  @@index([dueDate])
  @@index([relatedType, relatedId])
  @@map("tasks")
}

model TaskComment {
  id           String   @id @default(cuid())
  taskId       String
  authorUserId String
  body         String
  createdById  String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task   Task @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorUserId], references: [id])

  @@index([taskId])
  @@index([authorUserId])
  @@map("task_comments")
}

model TaskCollaborator {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation("TaskCollaborators", fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskCollaboratorUser", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_collaborators")
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  type        MeetingType   @default(video_call)
  status      MeetingStatus @default(scheduled)
  companyId   String?
  ownerUserId String
  start       DateTime
  end         DateTime?
  durationMin Int?
  location    String?
  agenda      String?
  notes       String?
  outcome     String?
  createdById String?
  updatedById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company Company? @relation("CompanyMeetings", fields: [companyId], references: [id])
  owner   User     @relation("MeetingOwner", fields: [ownerUserId], references: [id])

  attendees    MeetingAttendee[] @relation("MeetingAttendees")
  participants MeetingContact[]  @relation("MeetingContacts")

  @@index([companyId])
  @@index([ownerUserId])
  @@index([status])
  @@index([start])
  @@map("meetings")
}

model MeetingAttendee {
  id        String   @id @default(cuid())
  meetingId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation("MeetingAttendees", fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation("MeetingAttendeeUser", fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([userId])
  @@map("meeting_attendees")
}

model MeetingContact {
  id        String   @id @default(cuid())
  meetingId String
  contactId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation("MeetingContacts", fields: [meetingId], references: [id], onDelete: Cascade)
  contact Contact @relation("MeetingContactContact", fields: [contactId], references: [id])

  @@unique([meetingId, contactId])
  @@index([contactId])
  @@map("meeting_contacts")
}

model Activity {
  id             String              @id @default(cuid())
  type           ActivityType
  title          String
  body           String?
  companyId      String?
  contactId      String?
  relatedType    String?
  relatedId      String?
  actorUserId    String?
  actorContactId String?
  visibility     ActivityVisibility?
  occurredAt     DateTime            @default(now())
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company      Company? @relation("CompanyActivities", fields: [companyId], references: [id])
  contact      Contact? @relation("ContactActivities", fields: [contactId], references: [id])
  actor        User?    @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorContact Contact? @relation("ActivityActorContact", fields: [actorContactId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([actorUserId])
  @@index([type])
  @@index([relatedType, relatedId])
  @@index([occurredAt])
  @@map("activities")
}

model Notification {
  id                String           @id @default(cuid())
  type              NotificationType
  workspace         Workspace
  scope             Workspace?
  title             String
  body              String?
  priority          Priority         @default(medium)
  recipientUserId   String?
  audienceRoles     RoleKey[]
  audienceCompanyId String?
  companyId         String?
  relatedType       String?
  relatedId         String?
  href              String?
  read              Boolean          @default(false)
  readAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  recipient       User?    @relation("NotificationRecipient", fields: [recipientUserId], references: [id])
  audienceCompany Company? @relation("NotificationAudienceCompany", fields: [audienceCompanyId], references: [id])
  company         Company? @relation("NotificationSubjectCompany", fields: [companyId], references: [id])

  @@index([recipientUserId])
  @@index([audienceCompanyId])
  @@index([companyId])
  @@index([type])
  @@index([read])
  @@index([relatedType, relatedId])
  @@map("notifications")
}

model SupportRequest {
  id                  String          @id @default(cuid())
  reference           String          @unique
  companyId           String
  contactId           String?
  subject             String
  category            SupportCategory
  description         String
  priority            Priority        @default(medium)
  status              SupportStatus   @default(open)
  assignedOwnerUserId String?
  dueDate             DateTime?
  resolvedDate        DateTime?
  createdById         String?
  updatedById         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  company       Company  @relation("CompanySupportRequests", fields: [companyId], references: [id])
  contact       Contact? @relation("ContactSupportRequests", fields: [contactId], references: [id])
  assignedOwner User?    @relation("SupportRequestOwner", fields: [assignedOwnerUserId], references: [id])

  messages SupportMessage[] @relation("SupportRequestMessages")

  @@index([companyId])
  @@index([contactId])
  @@index([assignedOwnerUserId])
  @@index([status])
  @@index([category])
  @@map("support_requests")
}

model SupportMessage {
  id               String              @id @default(cuid())
  supportRequestId String
  authorUserId     String?
  authorContactId  String?
  visibility       ActivityVisibility?
  body             String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  supportRequest SupportRequest @relation("SupportRequestMessages", fields: [supportRequestId], references: [id], onDelete: Cascade)
  authorUser     User?          @relation("SupportMessageAuthorUser", fields: [authorUserId], references: [id])
  authorContact  Contact?       @relation("SupportMessageAuthorContact", fields: [authorContactId], references: [id])

  @@index([supportRequestId])
  @@index([authorUserId])
  @@index([authorContactId])
  @@map("support_messages")
}

model AssistantThread {
  id            String            @id @default(cuid())
  audience      AssistantAudience
  title         String?
  userId        String?
  companyId     String?
  actorRole     RoleKey?
  lastMessageAt DateTime?
  createdById   String?
  updatedById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user    User?    @relation("AssistantThreadUser", fields: [userId], references: [id])
  company Company? @relation("AssistantThreadCompany", fields: [companyId], references: [id])

  messages AssistantMessage[] @relation("ThreadMessages")

  @@index([userId])
  @@index([companyId])
  @@index([audience])
  @@index([lastMessageAt])
  @@map("assistant_threads")
}

model AssistantMessage {
  id                String                   @id @default(cuid())
  threadId          String
  role              AssistantMessageRole
  content           String
  toolName          String?
  toolArgs          Json?
  toolCallStatus    AssistantToolCallStatus?
  confirmedByUserId String?
  tokenUsage        Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  thread      AssistantThread @relation("ThreadMessages", fields: [threadId], references: [id], onDelete: Cascade)
  confirmedBy User?           @relation("AssistantMessageConfirmedBy", fields: [confirmedByUserId], references: [id])

  citations AssistantCitation[] @relation("MessageCitations")

  @@index([threadId])
  @@index([role])
  @@index([confirmedByUserId])
  @@index([toolCallStatus])
  @@map("assistant_messages")
}

model AssistantCitation {
  id              String                      @id @default(cuid())
  messageId       String
  targetType      AssistantCitationTargetType
  targetId        String?
  citedDocumentId String?
  label           String?
  snippet         String?
  accessLevel     DocumentAccessLevel?
  sourceUrl       String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  message       AssistantMessage @relation("MessageCitations", fields: [messageId], references: [id], onDelete: Cascade)
  citedDocument Document?        @relation("DocumentAssistantCitations", fields: [citedDocumentId], references: [id])

  @@index([messageId])
  @@index([targetType, targetId])
  @@index([citedDocumentId])
  @@map("assistant_citations")
}

/**
 * ══════════════════════════════ Gmail sync / leads / auth hardening ══════════════════════════════
 */

// A Gmail message synced into the CRM (inbound inbox mail or outbound mail sent
// from the admin UI). gmailMessageId is the dedupe key across sync runs.
model EmailMessage {
  id                 String         @id @default(cuid())
  gmailMessageId     String         @unique
  gmailThreadId      String
  direction          EmailDirection
  fromAddress        String
  fromName           String?
  toAddresses        String[]
  ccAddresses        String[]
  subject            String?
  snippet            String?
  bodyText           String?
  internalDate       DateTime
  hasAttachments     Boolean        @default(false)
  attachmentNames    String[]
  ndaDetected        Boolean        @default(false)
  ndaId              String?
  matchedAdminUserId String?
  leadId             String?
  companyId          String?
  sentByUserId       String?
  syncedAt           DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  matchedAdmin User? @relation("EmailMessageMatchedAdmin", fields: [matchedAdminUserId], references: [id], onDelete: SetNull)
  lead         Lead? @relation("LeadEmailMessages", fields: [leadId], references: [id], onDelete: SetNull)

  @@index([direction])
  @@index([internalDate])
  @@index([gmailThreadId])
  @@index([matchedAdminUserId])
  @@index([companyId])
  @@map("email_messages")
}

// "My Leads": one row per (admin, company name) extracted from Gmail
// ("Dear <admin>" greeting or the admin's signature on the first sent mail in
// the thread). Stores only the counterparty company NAME by design.
model Lead {
  id           String   @id @default(cuid())
  companyName  String
  adminUserId  String
  sourceDomain String?
  source       String   @default("gmail")
  emailCount   Int      @default(1)
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admin    User           @relation("LeadAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  messages EmailMessage[] @relation("LeadEmailMessages")

  @@unique([adminUserId, companyName])
  @@index([adminUserId])
  @@map("leads")
}

// Six-digit password-reset codes, stored hashed. A code is valid until
// expiresAt, for at most a fixed number of attempts, and only once.
model PasswordResetCode {
  id        String    @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  requestIp String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation("UserPasswordResetCodes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_codes")
}

// Fixed-window rate-limit counters (login, password reset, mail send, sync).
// key encodes scope + subject, e.g. "login:ip:1.2.3.4" or "reset:email:x@y".
model RateLimitEntry {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
  @@index([windowStart])
  @@map("rate_limit_entries")
}
