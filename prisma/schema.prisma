// ITALPROTEIN CRM — complete Prisma schema.
// Assembled from six domain specs (Identity/Access, Core commercial, Operational,
// Documents/NDA/Google, Finance, Engagement/AI). Canonical enum spellings come from
// lib/types.ts. Money = Int minor units + Currency enum. Quantities = Decimal + QuantityUnit.
// createdById/updatedById are PLAIN SCALAR audit columns (AuditEvent is the real trail).
// Named actor/owner FKs are real relations to User/Contact with explicit @relation names.
// Nullable historical actor FKs (AuditEvent.actorUser, EmailLog.recipientUser,
// DocumentAccessEvent.actor, ShipmentEvent.actor, OpportunityStageHistory.byUser,
// Activity.actor) use onDelete: SetNull so a User can be hard-deleted (Auth.js
// adapter expectation) while the immutable history row survives with a null actor.

// Prisma 7: the datasource connection URL lives in prisma.config.ts (DATABASE_URL),
// not in the schema. The datasource block declares only the provider.
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

