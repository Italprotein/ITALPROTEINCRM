/**
 * ══════════════════════════════ Identity / access models ══════════════════════════════
 */

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String?    @unique
  emailVerified   DateTime?
  image           String?
  roleId          String
  kind            UserKind   @default(internal)
  companyId       String?
  contactId       String?    @unique
  status          UserStatus @default(invited)
  passwordHash    String?
  mfaEnrolled     Boolean    @default(false)
  language        Locale     @default(en)
  lastLoginAt     DateTime?
  invitedByUserId String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Identity-domain relations
  role                   Role                   @relation("RoleUsers", fields: [roleId], references: [id])
  company                Company?               @relation("CompanyExternalUsers", fields: [companyId], references: [id])
  contact                Contact?               @relation("UserPortalContact", fields: [contactId], references: [id])
  invitedBy              User?                  @relation("UserInvitations", fields: [invitedByUserId], references: [id])
  invitedUsers           User[]                 @relation("UserInvitations")
  accounts               Account[]              @relation("UserAccounts")
  sessions               Session[]              @relation("UserSessions")
  mfaFactors             MfaFactor[]            @relation("UserMfaFactors")
  auditEvents            AuditEvent[]           @relation("AuditEventActor")
  emailLogs              EmailLog[]             @relation("EmailLogRecipient")
  registrationDecisions  RegistrationDecision[] @relation("RegistrationDecisionDecider")
  reviewedRegistrations  Registration[]         @relation("RegistrationReviewer")
  provisionedByDecisions RegistrationDecision[] @relation("RegistrationDecisionOwnerUser")

  // Core commercial back-relations
  ownedCompanies      Company[]                 @relation("CompanyOwner")
  ownedContacts       Contact[]                 @relation("ContactOwner")
  ownedOpportunities  Opportunity[]             @relation("OpportunityOwner")
  stageHistoryEntries OpportunityStageHistory[] @relation("StageHistoryActor")

  // Operational back-relations
  assignedSampleRequests SampleRequest[]      @relation("SampleRequestLogistics")
  ownedSampleRequests    SampleRequest[]      @relation("SampleRequestAccountOwner")
  approvedSampleRequests SampleRequest[]      @relation("SampleRequestApprovedBy")
  assignedShipments      Shipment[]           @relation("ShipmentLogistics")
  shipmentEvents         ShipmentEvent[]      @relation("ShipmentEventActor")
  ownedFeedbacks         Feedback[]           @relation("FeedbackTechnicalOwner")
  feedbackComments       FeedbackComment[]    @relation("FeedbackCommentAuthorUser")
  ownedProjectsInternal  ApplicationProject[] @relation("ProjectInternalOwner")
  ownedProjectsTechnical ApplicationProject[] @relation("ProjectTechnicalOwner")

  // Documents / NDA / Google back-relations
  uploadedDocuments        Document[]            @relation("DocumentUploadedBy")
  documentAccessEvents     DocumentAccessEvent[] @relation("DocumentAccessActor")
  ndaApprovals             NDA[]                 @relation("NDAApprovedBy")
  googleOAuthTokens        GoogleOAuthToken[]    @relation("GoogleTokenUser")
  linkedDriveFiles         GoogleDriveFileLink[] @relation("DriveLinkLinkedBy")
  uploadedAttachments      Attachment[]          @relation("AttachmentUploadedBy")
  uploadedDocumentVersions DocumentVersion[]     @relation("DocumentVersionUploadedBy")

  // Finance back-relations
  approvedQuotes    Quote[]      @relation("QuoteApprovedBy")
  confirmedOrders   Order[]      @relation("OrderConfirmedBy")
  issuedInvoices    Invoice[]    @relation("InvoiceIssuedBy")
  recordedPayments  Payment[]    @relation("PaymentRecordedBy")
  issuedCreditNotes CreditNote[] @relation("CreditNoteIssuedBy")

  // Engagement / AI back-relations
  ownedTasks                Task[]             @relation("TaskOwner")
  taskComments              TaskComment[]      @relation("TaskCommentAuthor")
  collaboratingTasks        TaskCollaborator[] @relation("TaskCollaboratorUser")
  ownedMeetings             Meeting[]          @relation("MeetingOwner")
  meetingAttendances        MeetingAttendee[]  @relation("MeetingAttendeeUser")
  activities                Activity[]         @relation("ActivityActor")
  notifications             Notification[]     @relation("NotificationRecipient")
  assignedSupportRequests   SupportRequest[]   @relation("SupportRequestOwner")
  supportMessages           SupportMessage[]   @relation("SupportMessageAuthorUser")
  assistantThreads          AssistantThread[]  @relation("AssistantThreadUser")
  confirmedAssistantActions AssistantMessage[] @relation("AssistantMessageConfirmedBy")

  // Gmail-sync / lead / password-reset back-relations
  matchedEmailMessages EmailMessage[]      @relation("EmailMessageMatchedAdmin")
  leads                Lead[]              @relation("LeadAdmin")
  passwordResetCodes   PasswordResetCode[] @relation("UserPasswordResetCodes")

  @@index([roleId])
  @@index([companyId])
  @@index([status])
  @@index([kind])
  @@index([invitedByUserId])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Auth.js adapter model — intentionally exempt from the id/createdAt/updatedAt
// convention. Its shape (composite @@unique([identifier, token]), no id PK, no
// updatedAt) is fixed by the NextAuth/Auth.js adapter contract.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MfaFactor {
  id           String          @id @default(cuid())
  userId       String
  type         MfaFactorType
  status       MfaFactorStatus @default(pending)
  label        String?
  secret       String?
  credentialId String?
  lastUsedAt   DateTime?
  verifiedAt   DateTime?
  createdById  String?
  updatedById  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation("UserMfaFactors", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("mfa_factors")
}

// The roles table — role.key holds the RoleKey enum value (super_admin, ...); mapped to "roles".
model Role {
  id          String   @id @default(cuid())
  key         RoleKey  @unique
  kind        RoleKind
  name        String?
  permissions Json?
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[] @relation("RoleUsers")

  @@index([kind])
  @@map("roles")
}

model Registration {
  id                    String                @id @default(cuid())
  reference             String                @unique
  status                RegistrationStatus    @default(submitted)
  legalName             String
  tradingName           String?
  companyType           CompanyType
  companySubtype        String?
  website               String?
  country               String
  countryCode           String
  region                String?
  city                  String
  address               String?
  postalCode            String?
  vatNumber             String?
  registrationNumber    String?
  mainActivity          String?
  companySize           CompanySize?
  marketsServed         String[]
  preferredLanguage     Locale                @default(en)
  preferredCurrency     Currency              @default(EUR)
  timezone              String?
  contactFirstName      String
  contactLastName       String
  contactJobTitle       String?
  contactDepartment     String?
  contactEmail          String
  contactPhone          String?
  contactMobile         String?
  contactLanguage       Locale?
  reason                String?
  existingContactPerson String?
  intendedApplications  ApplicationCategory[]
  productCategories     ApplicationCategory[]
  samplesRequested      Boolean?
  intendedTerritories   String[]
  estimatedTimeline     String?
  additionalMessage     String?
  privacyAccepted       Boolean               @default(false)
  termsAccepted         Boolean               @default(false)
  marketingOptIn        Boolean?
  linkedCompanyId       String?
  adminNote             String?
  decidedByUserId       String?
  decidedAt             DateTime?
  createdById           String?
  updatedById           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  decidedByUser User?                  @relation("RegistrationReviewer", fields: [decidedByUserId], references: [id])
  linkedCompany Company?               @relation("RegistrationLinkedCompany", fields: [linkedCompanyId], references: [id])
  decisions     RegistrationDecision[] @relation("RegistrationDecisions")

  @@index([status])
  @@index([contactEmail])
  @@index([linkedCompanyId])
  @@index([decidedByUserId])
  @@index([companyType])
  @@map("registrations")
}

model RegistrationDecision {
  id                     String                   @id @default(cuid())
  registrationId         String
  decision               RegistrationDecisionType
  reason                 String?
  note                   String?
  decidedByUserId        String
  decidedAt              DateTime                 @default(now())
  provisionedCompanyId   String?
  provisionedContactId   String?
  provisionedOwnerUserId String?
  createdById            String?
  updatedById            String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  registration         Registration @relation("RegistrationDecisions", fields: [registrationId], references: [id])
  decidedByUser        User         @relation("RegistrationDecisionDecider", fields: [decidedByUserId], references: [id])
  provisionedCompany   Company?     @relation("RegistrationDecisionCompany", fields: [provisionedCompanyId], references: [id])
  provisionedContact   Contact?     @relation("RegistrationDecisionContact", fields: [provisionedContactId], references: [id])
  provisionedOwnerUser User?        @relation("RegistrationDecisionOwnerUser", fields: [provisionedOwnerUserId], references: [id])

  @@index([registrationId])
  @@index([decidedByUserId])
  @@index([provisionedCompanyId])
  @@index([provisionedOwnerUserId])
  @@index([decision])
  @@map("registration_decisions")
}

model AuditEvent {
  id          String      @id @default(cuid())
  actorUserId String?
  actorRole   RoleKey?
  action      String
  entityType  String
  entityId    String?
  summary     String
  before      Json?
  after       Json?
  result      AuditResult @default(success)
  ip          String?
  userAgent   String?
  companyId   String?
  occurredAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  actorUser User? @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([companyId])
  @@index([result])
  @@index([occurredAt])
  @@map("audit_events")
}

model EmailLog {
  id                String           @id @default(cuid())
  trigger           NotificationType
  templateKey       String?
  to                String
  toAddresses       String[]
  cc                String[]
  subject           String
  preview           String?
  locale            Locale           @default(en)
  status            EmailLogStatus   @default(queued)
  providerMessageId String?
  error             String?
  attemptCount      Int              @default(0)
  recipientUserId   String?
  companyId         String?
  relatedEntityType String?
  relatedEntityId   String?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  recipientUser User? @relation("EmailLogRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([trigger])
  @@index([status])
  @@index([recipientUserId])
  @@index([companyId])
  @@index([relatedEntityType, relatedEntityId])
  @@map("email_logs")
}

