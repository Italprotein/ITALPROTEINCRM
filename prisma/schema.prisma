  updatedById          String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  company        Company?         @relation(fields: [companyId], references: [id])
  uploadedBy     User?            @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id])
